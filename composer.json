{
    "name": "aba/php-learning-api",
    "description": "User REST API",
    "type": "project",
    "require": {
        "php": "^8.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":      "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:int":  "phpunit --testsuite Integration",
        "stan":      "phpstan analyse"
    }
}
